{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        }
    },
    "functionTimeout": "00:05:00",
    "extensions": {
        "queues": {
            "maxPollingIntervalMs": 1000,
            "visibilityTimeout": "00:00:30"
        }
    }
}
